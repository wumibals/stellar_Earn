#!/usr/bin/env bash
# pre-push hook:
#   • Runs all verification checks before allowing a git push.
#   • Ensures format, lint, typecheck, tests, and changelog rules are satisfied.
#
# Skip:
#   SKIP_PRE_PUSH_HOOKS=1 git push
#

set -euo pipefail

# ── Colour helpers ────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

info()  { echo -e "${CYAN}[pre-push]${RESET} $*"; }
ok()    { echo -e "${GREEN}[pre-push] ✓${RESET} $*"; }
warn()  { echo -e "${YELLOW}[pre-push] ⚠${RESET} $*"; }
fail()  { echo -e "${RED}[pre-push] ✗${RESET} $*" >&2; }
header(){ echo -e "\n${BOLD}${CYAN}── $* ──${RESET}"; }

REPO_ROOT="$(git rev-parse --show-toplevel)"

if [[ "${SKIP_PRE_PUSH_HOOKS:-0}" == "1" ]]; then
  warn "SKIP_PRE_PUSH_HOOKS=1 — skipping all pre-push verification."
  exit 0
fi

FAILED=0

# ── Root Tests ───────────────────────────────────────────────────────────────
header "Root Test Suite"
cd "$REPO_ROOT"
if npm test; then
  ok "Root tests passed."
else
  fail "Root tests failed."
  FAILED=1
fi

# ── Frontend Checks ─────────────────────────────────────────────────────────
header "Frontend Checks (FrontEnd/my-app)"
FE_DIR="$REPO_ROOT/FrontEnd/my-app"

if [[ -d "$FE_DIR" ]]; then
  cd "$FE_DIR"

  # 1. Format check
  info "Checking Prettier formatting..."
  if npm run format:check; then
    ok "Formatting check passed."
  else
    fail "Formatting issues found! Run: npm run format"
    FAILED=1
  fi



  # 3. Typecheck
  info "Running TypeScript typecheck..."
  if npm run typecheck; then
    ok "Typecheck passed."
  else
    fail "TypeScript compilation failed."
    FAILED=1
  fi

  # 4. Vitest Unit Tests
  info "Running Vitest unit tests..."
  if npm run test; then
    ok "Unit tests passed."
  else
    fail "One or more unit tests failed."
    FAILED=1
  fi

  # 5. Changelog check
  info "Verifying Changelog policy compliance..."
  if npm run changelog:check; then
    ok "Changelog policy checks passed."
  else
    fail "Changelog validation failed! Watched files were modified without a changelog entry."
    FAILED=1
  fi
else
  warn "Frontend directory not found at $FE_DIR. Skipping frontend checks."
fi

# ── Result ────────────────────────────────────────────────────────────────────
echo ""
if [[ "$FAILED" -ne 0 ]]; then
  fail "Pre-push verification FAILED. Push blocked."
  echo ""
  echo -e "  To bypass in an emergency: ${BOLD}SKIP_PRE_PUSH_HOOKS=1 git push${RESET}"
  echo -e "  Or push with no-verify:   ${BOLD}git push --no-verify${RESET}"
  echo ""
  exit 1
fi

ok "All verification checks passed! Push allowed."
exit 0
