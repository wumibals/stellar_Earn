# Application
NODE_ENV=development
PORT=3000

# Logging Configuration
LOG_LEVEL=info
LOG_CONSOLE=true
LOG_FILE=true
LOG_DIR=logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d
LOG_PERFORMANCE=true
LOG_HEADERS=false
LOG_RESPONSE_BODY=false
LOG_RESPONSE_DATA=false

# Distributed Tracing (OpenTelemetry)
TRACING_ENABLED=false
TRACING_SERVICE_NAME=stellar-earn-api
TRACING_SERVICE_VERSION=1.0.0
OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Feature Flags
FF_ENABLE_DARK_MODE=false
FF_ENABLE_NEW_CHECKOUT=false
FF_ENABLE_BETA_QUESTS=false
FF_ENABLE_ADVANCED_ANALYTICS=false
FF_ENABLE_NOTIFICATIONS_V2=false

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/stellar_earn

# Connection Pool
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_CONNECTION_TIMEOUT=10000
DB_POOL_IDLE_TIMEOUT=30000

# Query Logging
DB_QUERY_LOGGING=true
SLOW_QUERY_THRESHOLD=1000
CRITICAL_QUERY_THRESHOLD=5000
DB_QUERY_LOG_LEVEL=debug

# Migrations
TYPEORM_MIGRATIONS_TABLE=typeorm_migrations
TYPEORM_MIGRATIONS_RUN=false

# Content moderation (optional external APIs)
MODERATION_BLOCK_HIGH=true
MODERATION_HIGH_THRESHOLD=0.85
MODERATION_MEDIUM_THRESHOLD=0.5
MODERATION_BLOCKED_KEYWORDS=
MODERATION_BLOCKED_IMAGE_HOSTS=
MODERATION_EXTERNAL_API_URL=
MODERATION_EXTERNAL_API_KEY=
MODERATION_IMAGE_API_URL=
MODERATION_IMAGE_API_KEY=

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

# Authentication Challenge
AUTH_CHALLENGE_EXPIRATION=5

# Rate Limiting (Global)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Per-User Rate Limiting Configuration
# Anonymous users (IP-based tracking)
RATE_LIMIT_ANONYMOUS_LIMIT=50
RATE_LIMIT_ANONYMOUS_TTL=60

# Regular authenticated users
RATE_LIMIT_USER_LIMIT=100
RATE_LIMIT_USER_TTL=60

# Verifiers (higher limits due to more operations)
RATE_LIMIT_VERIFIER_LIMIT=200
RATE_LIMIT_VERIFIER_TTL=60

# Auth endpoints for authenticated users
RATE_LIMIT_AUTH_USER_LIMIT=30
RATE_LIMIT_AUTH_USER_TTL=60

# Endpoint-specific limits
RATE_LIMIT_QUEST_CREATION_LIMIT=20
RATE_LIMIT_QUEST_CREATION_TTL=60
RATE_LIMIT_SUBMISSION_LIMIT=30
RATE_LIMIT_SUBMISSION_TTL=60
RATE_LIMIT_PAYOUT_LIMIT=10
RATE_LIMIT_PAYOUT_TTL=60

# Admins bypass rate limiting (no configuration needed)

# Admin Addresses (comma-separated Stellar addresses)
ADMIN_ADDRESSES=

# Admin IP Whitelist (comma-separated IPs; leave empty to allow all)
ADMIN_IP_WHITELIST=127.0.0.1,::1

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Email Configuration (SendGrid)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_WEBHOOK_VERIFICATION_KEY=your-webhook-verification-key
EMAIL_FROM_ADDRESS=noreply@stellarearn.com
EMAIL_FROM_NAME=Stellar Earn
EMAIL_REPLY_TO=support@stellarearn.com
APP_URL=http://localhost:3000
UNSUBSCRIBE_URL=http://localhost:3000/unsubscribe
EMAIL_QUEUE_MAX_RETRIES=5
EMAIL_QUEUE_RETRY_DELAY=5000
EMAIL_RATE_LIMIT=100

# WebSocket Configuration
WS_RATE_LIMIT_MAX=60
WS_RATE_LIMIT_WINDOW_MS=60000
WS_PING_INTERVAL=25000
WS_PING_TIMEOUT=20000
WS_MESSAGE_HISTORY_LIMIT=200

# CORS Configuration
# CORS_ORIGINS is also used for WS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Stellar Network Configuration
STELLAR_NETWORK=testnet
# Used for Horizon API calls (e.g. account sequence)
HORIZON_URL=https://horizon-testnet.stellar.org
# Ledger confirmations required before submitted payouts move to completed
STELLAR_FINALITY_CONFIRMATIONS=3
# Used for Soroban RPC calls (e.g. invoke contract)
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Contract ID to interact with
CONTRACT_ID=C...

# OAuth2 Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback
# Source account secret key
STELLAR_SOURCE_SECRET_KEY=S...
SOROBAN_SECRET_KEY=S...
STELLAR_ADMIN_SECRET=
